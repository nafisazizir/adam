{
  "name": "adam",
  "version": "0.0.0",
  "type": "module",
  "imports": {
    "#*": "./agent/*",
    "#evals/*": "./evals/*"
  },
  "scripts": {
    "build": "eve build",
    "dev": "eve dev",
    "start": "eve start",
    "typecheck": "tsgo",
    "telegram:webhook:set:dev": "node --env-file=.env.local scripts/telegram-webhook.ts set",
    "telegram:webhook:info:dev": "node --env-file=.env.local scripts/telegram-webhook.ts info",
    "telegram:webhook:delete:dev": "node --env-file=.env.local scripts/telegram-webhook.ts delete",
    "telegram:webhook:set:prod": "node --env-file=.env.production scripts/telegram-webhook.ts set",
    "telegram:webhook:info:prod": "node --env-file=.env.production scripts/telegram-webhook.ts info",
    "telegram:webhook:delete:prod": "node --env-file=.env.production scripts/telegram-webhook.ts delete"
  },
  "dependencies": {
    "@upstash/qstash": "^2.11.1",
    "@vercel/connect": "0.2.2",
    "ai": "7.0.0-beta.178",
    "eve": "^0.11.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.x",
    "@typescript/native-preview": "7.0.0-dev.20260523.1"
  },
  "overrides": {
    "ai": "7.0.0-beta.178"
  },
  "resolutions": {
    "ai": "7.0.0-beta.178"
  },
  "engines": {
    "node": "24.x"
  }
}
